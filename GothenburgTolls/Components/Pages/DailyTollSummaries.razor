@page "/dailytollsummaries"
@rendermode InteractiveServer
@inject IDailyTollSummaryService DailyTollSummaryService
@inject IVehicleService VehicleService
@implements IDisposable

<PageTitle>Daily Summaries</PageTitle>

<div class="page-header">
    <h1>Daily Toll Summaries</h1>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card-toll">
            <div class="card-header">Create Daily Summary</div>
            <div class="card-body">
                <div class="mb-3">
                    <label for="regNr" class="form-label fw-semibold">Registration Number</label>
                    <input id="regNr" class="form-control" @bind="_registrationNumber" placeholder="ABC123" />
                </div>
                <div class="mb-3">
                    <label for="forDay" class="form-label fw-semibold">Date</label>
                    <input id="forDay" type="date" class="form-control" @bind="_forDay" />
                </div>
                <button class="btn btn-primary" @onclick="CreateSummaryAsync" disabled="@_isCreating">
                    @(_isCreating ? "Creating..." : "Create Summary")
                </button>
            </div>
        </div>
    </div>
</div>

<ErrorAlert Message="@_error" />

@if (_createdSummary is not null)
{
    <SuccessAlert Message="@($"Summary created for {_createdSummary.ForDay:yyyy-MM-dd} — Amount: {_createdSummary.Amount} SEK")" />
}

<div class="card-toll">
    <div class="card-header">Uninvoiced Summaries</div>
    <div class="card-body p-0">
        @if (_summaries is null)
        {
            <LoadingIndicator />
        }
        else if (_summaries.Count == 0)
        {
            <EmptyState Message="No uninvoiced summaries found." />
        }
        else
        {
            <DailyTollSummaryTable Summaries="_summaries" />
        }
    </div>
</div>

@code {
    private readonly CancellationTokenSource _cts = new();
    private string _registrationNumber = string.Empty;
    private DateOnly _forDay = DateOnly.FromDateTime(DateTime.Today.AddDays(-1));
    private bool _isCreating;
    private string? _error;
    private DailyTollSummary? _createdSummary;
    private List<DailyTollSummary>? _summaries;

    protected override async Task OnInitializedAsync()
    {
        await LoadSummariesAsync();
    }

    private async Task LoadSummariesAsync()
    {
        try
        {
            _summaries = await DailyTollSummaryService.GetAllUninvoicedAsync(_cts.Token);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task CreateSummaryAsync()
    {
        _isCreating = true;
        _error = null;
        _createdSummary = null;

        try
        {
            _createdSummary = await DailyTollSummaryService.CreateAsync(
                _registrationNumber, _forDay, _cts.Token);

            await LoadSummariesAsync();
        }
        catch (OperationCanceledException)
        {

        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isCreating = false;
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}

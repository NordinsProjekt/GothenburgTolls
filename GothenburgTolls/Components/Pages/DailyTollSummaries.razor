@page "/dailytollsummaries"
@rendermode InteractiveServer
@using Entities.Tolls
@using UseCases.Interfaces
@inject IDailyTollSummaryService DailyTollSummaryService
@inject IVehicleService VehicleService
@implements IDisposable

<PageTitle>Daily Toll Summaries</PageTitle>

<h1>Skapa daglig avgiftssammanfattning</h1>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="mb-3">
            <label for="regNr" class="form-label">Registreringsnummer</label>
            <input id="regNr" class="form-control" @bind="_registrationNumber" placeholder="ABC123" />
        </div>
        <div class="mb-3">
            <label for="forDay" class="form-label">Datum</label>
            <input id="forDay" type="date" class="form-control" @bind="_forDay" />
        </div>
        <button class="btn btn-primary" @onclick="CreateSummaryAsync" disabled="@_isCreating">
            @(_isCreating ? "Skapar..." : "Skapa sammanfattning")
        </button>
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (_createdSummary is not null)
{
    <div class="alert alert-success">
        Sammanfattning skapad för @_createdSummary.ForDay.ToString("yyyy-MM-dd") med belopp @_createdSummary.Amount kr.
    </div>
}

@if (_summaries is not null)
{
    <h2 class="mt-4">Sammanfattningar</h2>

    @if (_summaries.Count == 0)
    {
        <p>Inga sammanfattningar hittades.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Datum</th>
                    <th>Belopp</th>
                    <th>Skapad</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var summary in _summaries)
                {
                    <tr>
                        <td>@summary.ForDay.ToString("yyyy-MM-dd")</td>
                        <td>@summary.Amount kr</td>
                        <td>@summary.Created.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private readonly CancellationTokenSource _cts = new();
    private string _registrationNumber = string.Empty;
    private DateOnly _forDay = DateOnly.FromDateTime(DateTime.Today.AddDays(-1));
    private bool _isCreating;
    private string? _error;
    private DailyTollSummary? _createdSummary;
    private List<DailyTollSummary>? _summaries;

    private async Task CreateSummaryAsync()
    {
        _isCreating = true;
        _error = null;
        _createdSummary = null;

        try
        {
            _createdSummary = await DailyTollSummaryService.CreateAsync(
                _registrationNumber, _forDay, _cts.Token);

            _summaries = await DailyTollSummaryService.GetAllByVehicleIdAsync(
                _createdSummary.VehicleId, _cts.Token);
        }
        catch (OperationCanceledException)
        {

        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isCreating = false;
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}

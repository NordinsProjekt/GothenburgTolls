@page "/"

<PageTitle>Dashboard – GothenburgTolls</PageTitle>

<div class="page-header">
    <h1>Dashboard</h1>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card-toll">
            <div class="card-header">Toll Events</div>
            <div class="card-body stat-card">
                <p class="mb-2">View and monitor all vehicle passages through toll stations in real time.</p>
                <a href="tollevents" class="btn btn-outline-primary btn-sm">View Events →</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card-toll">
            <div class="card-header">Daily Summaries</div>
            <div class="card-body stat-card">
                <p class="mb-2">Generate daily toll summaries per vehicle to prepare for invoicing.</p>
                <a href="dailytollsummaries" class="btn btn-outline-primary btn-sm">Manage Summaries →</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card-toll">
            <div class="card-header">Invoices</div>
            <div class="card-body stat-card">
                <p class="mb-2">Create and review monthly toll invoices for registered vehicles.</p>
                <a href="tollinvoices" class="btn btn-outline-primary btn-sm">View Invoices →</a>
            </div>
        </div>
    </div>
</div>

<div class="card-toll">
    <div class="card-body text-center py-5">
        <h4 style="color:#0f172a;">Welcome to Gothenburg Congestion Tax Management</h4>
        <p class="text-muted mb-0">Use the navigation to manage toll events, daily summaries, and invoices.</p>
    </div>
</div>

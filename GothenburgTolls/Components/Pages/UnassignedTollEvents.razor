@page "/unassignedtollevents"
@rendermode InteractiveServer
@using Entities.Tolls
@using UseCases.Interfaces
@inject ITollEventService TollEventService
@implements IDisposable

<PageTitle>Unassigned Events</PageTitle>

<div class="page-header">
    <h1>Unassigned Events</h1>
    <span class="badge bg-warning text-dark">Pending</span>
</div>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="LoadAsync" disabled="@_isLoading">
        @(_isLoading ? "Loading..." : "⟳ Refresh")
    </button>
</div>

@if (_error is not null)
{
    <div class="alert-toll-error p-3 mb-3">@_error</div>
}

<div class="card-toll">
    <div class="card-header">Passages Without Daily Summary</div>
    <div class="card-body p-0">
        @if (_events is null)
        {
            <div class="p-4 text-center text-muted">Loading...</div>
        }
        else if (_events.Count == 0)
        {
            <div class="empty-state">
                <p>All passages have been assigned to daily summaries.</p>
            </div>
        }
        else
        {
            <table class="table table-toll mb-0">
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>Zone</th>
                        <th>Registration No.</th>
                        <th>Vehicle Type</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ev in _events)
                    {
                        <tr>
                            <td>@ev.EventDateTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@ev.Zone</td>
                            <td><strong>@(ev.Vehicle?.RegistrationNumber ?? "-")</strong></td>
                            <td>@(ev.Vehicle?.GetType().Name ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private const int MaxCount = 100;
    private readonly CancellationTokenSource _cts = new();

    private IReadOnlyList<TollEvent>? _events;
    private bool _isLoading;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            _events = await TollEventService.GetUnassignedAsync(MaxCount, _cts.Token);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
